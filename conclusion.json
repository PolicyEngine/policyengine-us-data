{"version":3,"kind":"Article","sha256":"0f84d57b63dc9ef07879297691782adc66974b510ed0214161d9c756985c0c23","slug":"conclusion","location":"/conclusion.md","dependencies":[],"frontmatter":{"title":"Conclusion","content_includes_title":false,"authors":[{"nameParsed":{"given":"PolicyEngine","family":"Team","literal":"PolicyEngine Team"},"name":"PolicyEngine Team","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/policyengine/policyengine-us-data","copyright":"2024","source_url":"https://github.com/policyengine/policyengine-us-data/blob/main/docs/conclusion.md","edit_url":"https://github.com/policyengine/policyengine-us-data/edit/main/docs/conclusion.md","exports":[{"format":"md","filename":"conclusion.md","url":"/policyengine-us-data/build/conclusion-6a56a77b30a340d0b608c9ddd98988ac.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"We present a methodology for creating enhanced microsimulation datasets that combine the strengths\nof survey and administrative data sources. The Enhanced CPS dataset demonstrates that careful\napplication of modern statistical methods can substantially improve the data available for policy\nanalysis.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GmlFFQySSl"}],"key":"xPsV5UOUJT"},{"type":"heading","depth":2,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Summary of Contributions","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"LfoHz1rXam"}],"identifier":"summary-of-contributions","label":"Summary of Contributions","html_id":"summary-of-contributions","implicit":true,"key":"Pc8gkF5pWx"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Our work makes several key contributions:","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"vNDHoQ9ZQE"}],"key":"yQPmoAc9qY"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Methodological Innovation","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"Bwir0nnZHw"}],"key":"l0Nvi3Me0Y"},{"type":"text","value":": The use of Quantile Regression Forests for imputation preserves\ndistributional characteristics while maintaining computational efficiency. The large-scale\ncalibration to 2,813 targets pushes the boundaries of survey data enhancement.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"WG8Iz3ZmOM"}],"key":"r5aZ73l0gJ"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"strong","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Practical Tools","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Y5IPfGvULM"}],"key":"X2NLM9I1yU"},{"type":"text","value":": We provide open-source implementations that enable researchers to apply,\nmodify, and extend these methods. The modular design facilitates experimentation with alternative\napproaches.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"GWXqjQn0Ni"}],"key":"pxJmCS7tjz"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"strong","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"Validated Dataset","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"slxaivDfkU"}],"key":"VSfcWEtqwj"},{"type":"text","value":": The Enhanced CPS itself serves as a public good for the research community,\nenabling studies that would otherwise require restricted data access.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"YpR1zYj5LM"}],"key":"kic0dDlWIz"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"strong","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Reproducible Research","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"KPuRfVyZUP"}],"key":"GSFagbmSyd"},{"type":"text","value":": All code, data, and documentation are publicly available, supporting\nreproducibility and collaborative improvement.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"HR3KKtIhg8"}],"key":"mJa4PFvwp1"},{"type":"heading","depth":2,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Key Findings","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"UgswXgBtpo"}],"identifier":"key-findings","label":"Key Findings","html_id":"key-findings","implicit":true,"key":"ghgoWvAzht"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"The validation results demonstrate that combining survey and administrative data through principled\nstatistical methods can achieve:","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"W8HbnNmGde"}],"key":"WhsvYoSHBR"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":31,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Improved income distribution representation","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"uoX2r97g2o"}],"key":"uVaTfUjp66"}],"key":"ixcXKuW7OM"},{"type":"listItem","spread":true,"position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Better alignment with program participation totals","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"sXV3xuM1rq"}],"key":"IjpcrPVE1k"}],"key":"TVeiZgUIBL"},{"type":"listItem","spread":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Maintained demographic and geographic detail","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"pI4htXu6Z2"}],"key":"uDcZrwA0AF"}],"key":"W0lOs8p850"},{"type":"listItem","spread":true,"position":{"start":{"line":34,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Suitable accuracy for policy simulation","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"HNENN2qHjy"}],"key":"al0CBLQJVQ"}],"key":"UaupS0mwcJ"}],"key":"aPWPt9yPbl"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"While no dataset perfectly represents the full population, the Enhanced CPS provides a pragmatic\nbalance of accuracy, detail, and accessibility.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"SjWMbRvHNz"}],"key":"NBCRGET68Z"},{"type":"heading","depth":2,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Implications for Policy Analysis","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"jB9JL00gZS"}],"identifier":"implications-for-policy-analysis","label":"Implications for Policy Analysis","html_id":"implications-for-policy-analysis","implicit":true,"key":"nWhjrQ4pA2"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Enhanced microdata availability creates immediate implications for policy analysis. More accurate\nrepresentation of high incomes enables better analysis of progressive tax reforms and revenue\nestimates. Researchers can now analyze tax and transfer policies jointly rather than in isolation.\nGeographic identifiers enable subnational policy analysis not possible with administrative tax data\nalone. Finally, household structure allows examination of policy impacts across family types and\nincome levels.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"eYoeXwXr3P"}],"key":"ECjmWmmXLN"},{"type":"heading","depth":2,"position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Broader Implications","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"XU9OPjdtN8"}],"identifier":"broader-implications","label":"Broader Implications","html_id":"broader-implications","implicit":true,"key":"xynnsBLAYW"},{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Beyond the specific dataset, this work demonstrates several broader principles. Combining multiple\ndata sources can overcome individual limitations, showing the value of data integration. Making\nmethods and data publicly available accelerates research progress and demonstrates open science\nbenefits. While perfect data may never exist, pragmatic enhancements can substantially improve\nanalysis capabilities. Furthermore, open-source approaches enable community contributions and\ncontinuous improvement.","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"KhDCJXW6xR"}],"key":"WflwAZrTHM"},{"type":"heading","depth":2,"position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"Limitations and Future Work","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"CYUyCSRcmL"}],"identifier":"limitations-and-future-work","label":"Limitations and Future Work","html_id":"limitations-and-future-work","implicit":true,"key":"cSrLz7oQMZ"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"We acknowledge important limitations including temporal inconsistency between data sources,\nimputation model assumptions, calibration trade-offs, and validation challenges. Future work should\naddress these through more recent administrative data, enhanced imputation methods, additional\nvalidation exercises, and uncertainty quantification.","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"QzvvUoMIc4"}],"key":"iL66RNQUMg"},{"type":"heading","depth":2,"position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"Call to Action","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"ROnQW5OIi2"}],"identifier":"call-to-action","label":"Call to Action","html_id":"call-to-action","implicit":true,"key":"mpBWKTuQaA"},{"type":"paragraph","position":{"start":{"line":66,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"We encourage researchers to apply the Enhanced CPS to policy questions where combined demographic\nand tax detail adds value, compare findings with other data sources and contribute validation\nresults, leverage the open-source nature to make methodological enhancements, and document use\ncases, limitations discovered, and suggested improvements.","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"nQvdbBlRZG"}],"key":"nMbQnaO1Wl"},{"type":"heading","depth":2,"position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"Final Thoughts","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"rwdoGFq0jB"}],"identifier":"final-thoughts","label":"Final Thoughts","html_id":"final-thoughts","implicit":true,"key":"GamMKi77MT"},{"type":"paragraph","position":{"start":{"line":73,"column":1},"end":{"line":75,"column":1}},"children":[{"type":"text","value":"The Enhanced CPS represents one approach to a fundamental challenge in microsimulation: the need for\ncomprehensive, accurate microdata. While not perfect, it demonstrates that substantial improvements\nare possible through careful methodology and open collaboration.","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"key":"GTajbEaYb8"}],"key":"EhMLk6XZ2z"},{"type":"paragraph","position":{"start":{"line":77,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"As data availability evolves and methods advance, this work contributes to a future where policy\nanalysis rests on increasingly solid empirical foundations. Our ultimate goal remains better\ninformed policy decisions that improve social welfare.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"lRp3EZZyMh"}],"key":"zv2lRs7Jjj"},{"type":"paragraph","position":{"start":{"line":81,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"The enhanced dataset, complete documentation, and all source code are available at\n","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"IqFL73QL6R"},{"type":"link","url":"https://github.com/PolicyEngine/policyengine-us-data","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"https://​github​.com​/PolicyEngine​/policyengine​-us​-data","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"puFXMVIGkf"}],"urlSource":"https://github.com/PolicyEngine/policyengine-us-data","error":true,"key":"eutzUje5CZ"},{"type":"text","value":".","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"mJpcKHSegm"}],"key":"BaSwIDiaJL"}],"key":"BpuDFlQKHR"}],"key":"nG6d4f8xMs"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Discussion","url":"/discussion","group":"PolicyEngine US Data"},"next":{"title":"Appendix","url":"/appendix","group":"PolicyEngine US Data"}}},"domain":"http://localhost:3000"}