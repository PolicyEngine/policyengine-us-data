 sources below","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"i1oBKTrtQc"}],"key":"PKVXbE6xRV"}],"key":"Fad1abS5fl"}],"key":"Py6fSrKDcr"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Primary Data Sources","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"angGMSoi9Y"}],"identifier":"primary-data-sources","label":"Primary Data Sources","html_id":"primary-data-sources","implicit":true,"key":"L0YoXCrkw1"},{"type":"heading","depth":3,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Current Population Survey (CPS)","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"yKQDmPu9lq"}],"identifier":"current-population-survey-cps","label":"Current Population Survey (CPS)","html_id":"current-population-survey-cps","implicit":true,"key":"nVOOMbV8Sb"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"The Current Population Survey Annual Social and Economic Supplement (ASEC) serves as our base\ndataset. The Census Bureau and Bureau of Labor Statistics jointly conduct the CPS ASEC, surveying\nhouseholds annually.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"lz7tFzgRfb"}],"key":"pcNTP0764q"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"The CPS provides features for microsimulation modeling. It offers a representative sample of US\nhouseholds with demographic information including age, education, race, and employment status. The\nsurvey captures family and household relationships through relationship codes that allow\nreconstruction of tax units and benefit units. Geographic identifiers down to the state level enable\nsubnational policy analysis. The survey includes questions about program participation in transfer\nprograms like SNAP, Medicaid, and housing assistance. The survey collects income data by source,\ndistinguishing between wages, self-employment, interest, dividends, and transfers.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"nznBfLmSlm"}],"key":"uJMOzhEdOW"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"The CPS faces limitations that necessitate enhancement. Income underreporting is severe at high\nincome levels ","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"gkI03cOvaB"},{"type":"citeGroup","kind":"parenthetical","children":[{"type":"cite","kind":"parenthetical","label":"rothbaum2021","identifier":"rothbaum2021","children":[{"type":"text","value":"Rothbaum & Bee, 2021","key":"Ez68Oe3gxT"}],"enumerator":"1","key":"xKWVfc8fwE"}],"key":"GbtTxgUxV7"},{"type":"text","value":". The survey provides limited tax detail, lacking information on\nitemized deductions, tax credits, and capital gains realizations. The Census Bureau topcodes high\nincome values to protect confidentiality. The survey’s focus on cash income means it misses non-cash\ncompensation like employer-provided health insurance premiums.","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"FOuHZSGsFe"}],"key":"eEfKrYTRQi"},{"type":"heading","depth":3,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"IRS Public Use File (PUF)","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"CUefchvBO1"}],"identifier":"irs-public-use-file-puf","label":"IRS Public Use File (PUF)","html_id":"irs-public-use-file-puf","implicit":true,"key":"CuTlIej3wO"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"The IRS Statistics of Income Public Use File contains tax return information that the IRS draws from\na stratified sample of individual income tax returns.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"E3We92xiCb"}],"key":"rxu3xuzhFE"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"The PUF provides tax-related variables drawn from filed tax returns. It provides breakdowns of\nincome by source including wages, interest, dividends, capital gains, business income, and\nretirement distributions. The file includes itemized deductions such as mortgage interest, state and\nlocal taxes, and charitable contributions. The file includes tax credits that filers claim, from the\nearned income tax credit to education credits. The stratified sampling design oversamples\nhigh-income returns. Sampling weights allow researchers to produce population-representative\nestimates.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"hvz2Pb0coX"}],"key":"t7wtozQaUL"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"The PUF has limitations for policy analysis. The file contains minimal demographic information,\nlimited to filing status and exemptions claimed. The IRS removes geographic identifiers to protect\ntaxpayer privacy, which prevents state-level analysis. The population excludes non-filers. The PUF\nlacks household structure, preventing analysis of how tax policies interact with transfer programs\nthat operate at the household level.","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"WsICPtd7z0"}],"key":"YRp0Emt4e9"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"The enhanced dataset retains the full CPS population, including non-filers. CPS copy-1 records keep\noriginal CPS income values for all households, covering non-filers and low-income households absent\nfrom PUF. Only copy-2 records replace income variables with PUF imputations and represent the filer\npopulation. This structure preserves non-filer coverage while enriching the tax detail for filers.","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"flDTQWoday"}],"key":"jt8cH1m4p4"},{"type":"heading","depth":2,"position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"Additional Data Sources for Imputation","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"CRT12ihXHL"}],"identifier":"additional-data-sources-for-imputation","label":"Additional Data Sources for Imputation","html_id":"additional-data-sources-for-imputation","implicit":true,"key":"hBy2CYGl0t"},{"type":"paragraph","position":{"start":{"line":65,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Beyond the PUF, we incorporate data from three additional surveys to impute specific variables\nmissing from the CPS:","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"vd3K20Otpe"}],"key":"kqMgtJznRg"},{"type":"heading","depth":3,"position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"Survey of Income and Program Participation (SIPP)","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"ZINciLztYU"}],"identifier":"survey-of-income-and-program-participation-sipp","label":"Survey of Income and Program Participation (SIPP)","html_id":"survey-of-income-and-program-participation-sipp","implicit":true,"key":"zlx9QU4jdY"},{"type":"paragraph","position":{"start":{"line":70,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"The SIPP provides income and program participation data. We use SIPP primarily to impute tip income\nthrough a Quantile Regression Forest model trained on SIPP data, using employment income, age, and\nhousehold composition as predictors.","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"LJ8FsDxCF2"}],"key":"qUU0s9dyD0"},{"type":"heading","depth":3,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Survey of Consumer Finances (SCF)","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"sBZUUajnXt"}],"identifier":"survey-of-consumer-finances-scf","label":"Survey of Consumer Finances (SCF)","html_id":"survey-of-consumer-finances-scf","implicit":true,"key":"Xv9vH7jP14"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"The SCF provides wealth and debt information that we use to impute several financial variables\nmissing from the CPS. We match auto loan balances based on household demographics and income, then\ncalculate interest on auto loans from these imputed balances. Additionally, we impute various net\nworth components and other wealth measures not available in CPS. The SCF imputation uses their\nreference person definition to ensure proper matching.","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"mFwAWJ6oiQ"}],"key":"lfNj7kvCqs"},{"type":"heading","depth":3,"position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"American Community Survey (ACS)","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"MOeCh8u4EK"}],"identifier":"american-community-survey-acs","label":"American Community Survey (ACS)","html_id":"american-community-survey-acs","implicit":true,"key":"xcMZ9kSShN"},{"type":"paragraph","position":{"start":{"line":84,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"The ACS provides housing and geographic data that supplements the CPS housing information. For\nhomeowners, we impute property taxes based on state of residence, household income, and demographic\ncharacteristics. We also impute rent values for specific tenure types where CPS data is incomplete,\nalong with additional housing characteristics not captured in the CPS. These imputations use\nQuantile Regression Forests to preserve distributional characteristics while accounting for\nhousehold heterogeneity.","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"ON2RpJWYKv"}],"key":"ICn3hQB0zT"},{"type":"heading","depth":2,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Calibration Data Sources","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"hIGUg5JS8x"}],"identifier":"calibration-data-sources","label":"Calibration Data Sources","html_id":"calibration-data-sources","implicit":true,"key":"KvDeF9WimU"},{"type":"paragraph","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"The calibration process uses targets from six administrative sources:","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"iakDUK0nO5"}],"key":"fCqMElR1kN"},{"type":"heading","depth":3,"position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"IRS Statistics of Income (SOI)","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"E2nPG4r9xm"}],"identifier":"irs-statistics-of-income-soi","label":"IRS Statistics of Income (SOI)","html_id":"irs-statistics-of-income-soi","implicit":true,"key":"CnBpWJjOdy"},{"type":"paragraph","position":{"start":{"line":97,"column":1},"end":{"line":98,"column":1}},"children":[{"type":"text","value":"The IRS SOI provides tax return aggregates by income level, filing status, and geography. These\ninclude counts of returns, aggregate income by source, deduction amounts, and credit utilization.","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"tDo2IksWHS"}],"key":"RrL6s87gqz"},{"type":"heading","depth":3,"position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"text","value":"Census Population Estimates","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"EU4SBRawX6"}],"identifier":"census-population-estimates","label":"Census Population Estimates","html_id":"census-population-estimates","implicit":true,"key":"QW3GoEfMjY"},{"type":"paragraph","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Census provides population counts by age, state, and other demographic characteristics.","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"qGhwSq84S1"}],"key":"D21LUxOxYF"},{"type":"heading","depth":3,"position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Congressional Budget Office","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"Qy1P3i1kVk"}],"identifier":"congressional-budget-office","label":"Congressional Budget Office","html_id":"congressional-budget-office","implicit":true,"key":"XCro7qcUnE"},{"type":"paragraph","position":{"start":{"line":106,"column":1},"end":{"line":107,"column":1}},"children":[{"type":"text","value":"CBO provides projections for program participation and spending, including SNAP benefits,\nunemployment compensation, and tax revenues.","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"QEalyo5owM"}],"key":"h8gJYacTJo"},{"type":"heading","depth":3,"position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"children":[{"type":"text","value":"Joint Committee on Taxation","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"SReklfLD7X"}],"identifier":"joint-committee-on-taxation","label":"Joint Committee on Taxation","html_id":"joint-committee-on-taxation","implicit":true,"key":"mKo91aGag9"},{"type":"paragraph","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"JCT provides estimates of tax expenditures for major deductions and credits.","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"SLTBYOQYdK"}],"key":"nw1Qo6KMA6"},{"type":"heading","depth":3,"position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"children":[{"type":"text","value":"Healthcare Spending Data","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"LKYxCtltvT"}],"identifier":"healthcare-spending-data","label":"Healthcare Spending Data","html_id":"healthcare-spending-data","implicit":true,"key":"pwXyMQDT4y"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":116,"column":1}},"children":[{"type":"text","value":"Various sources provide data on health insurance premiums, Medicare costs, and medical spending by\nage group.","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"YBSOb6r6yG"}],"key":"hsXAakxBBC"},{"type":"heading","depth":3,"position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"text","value":"State Administrative Data","position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"key":"rGJ4OaowcQ"}],"identifier":"state-administrative-data","label":"State Administrative Data","html_id":"state-administrative-data","implicit":true,"key":"fLQmqubY0p"},{"type":"paragraph","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"children":[{"type":"text","value":"State-level program participation and spending data from various state agencies.","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"wZFHkq0TBn"}],"key":"Jj0mCqbjuS"},{"type":"heading","depth":2,"position":{"start":{"line":122,"column":1},"e