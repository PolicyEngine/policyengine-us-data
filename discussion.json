ins realistic variable correlations","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"cnIwsvG9Tz"}],"key":"iAoOHzo6xJ"}],"key":"VFtcYcbZTq"},{"type":"listItem","spread":true,"position":{"start":{"line":28,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Allows uncertainty quantification","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"amy0kvSMnx"}],"key":"paX0scPCte"}],"key":"oEJfgldeVM"}],"key":"N2IUZwhNCI"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"The large-scale calibration to 2,813 targets ensures consistency with administrative benchmarks\nacross multiple dimensions simultaneously.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"cKwqlOjxLM"}],"key":"twpYRUNxGf"},{"type":"heading","depth":3,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Practical Advantages","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"cxaAji0yg1"}],"identifier":"practical-advantages","label":"Practical Advantages","html_id":"practical-advantages","implicit":true,"key":"lmor9SJIXM"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"For policy analysis, the dataset offers several key features: state-level geographic detail for\nsubnational analysis, household structure for distributional studies, tax detail for revenue\nestimation, program participation for benefit analysis, and calibration to current administrative\ntotals.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"Hz3kjYZlpI"}],"key":"dINJcouRHK"},{"type":"heading","depth":2,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Limitations","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"urPQ57QlnT"}],"identifier":"limitations","label":"Limitations","html_id":"limitations","implicit":true,"key":"EO7RES0p4z"},{"type":"heading","depth":3,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Temporal Inconsistency","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"b0xzDOX51Y"}],"identifier":"temporal-inconsistency","label":"Temporal Inconsistency","html_id":"temporal-inconsistency","implicit":true,"key":"tHVv0nhi1L"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"The temporal gap between data sources presents a limitation, with 2015 PUF data imputed onto 2024\nCPS creating a nine-year gap in underlying populations. This gap means demographic shifts are not\nfully captured, and tax law changes since 2015 are not reflected in the imputed variables.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"kvHxhecSG2"}],"key":"XtxGKmhehk"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"While we uprate dollar amounts and calibration partially addresses this, we may not reflect\nfundamental demographic changes.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"vlFZjQxyHW"}],"key":"UZAlsLFdBc"},{"type":"heading","depth":3,"position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Imputation Assumptions","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"JJqPbfY0PX"}],"identifier":"imputation-assumptions","label":"Imputation Assumptions","html_id":"imputation-assumptions","implicit":true,"key":"CNhGwOFJYU"},{"type":"paragraph","position":{"start":{"line":53,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"The QRF imputation assumes that relationships between demographics and tax variables remain stable,\nseven predictors sufficiently capture variation, the PUF represents the tax-filing population well,\nand missing data patterns are ignorable.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"xpo3Poqjrs"}],"key":"HOMNTwKr2o"},{"type":"paragraph","position":{"start":{"line":57,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"text","value":"These assumptions may not hold perfectly, particularly for subpopulations that the PUF\nunderrepresents.","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"oiTVdUe4ke"}],"key":"KWztodjraE"},{"type":"heading","depth":3,"position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"children":[{"type":"text","value":"Calibration Trade-offs","position":{"start":{"line":60,"column":1},"end":{"line":60,"column":1}},"key":"AiF1Xq0szC"}],"identifier":"calibration-trade-offs","label":"Calibration Trade-offs","html_id":"calibration-trade-offs","implicit":true,"key":"HMuzzxgxsS"},{"type":"paragraph","position":{"start":{"line":62,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"With 2,813 targets, perfect fit to all benchmarks is impossible. The optimization must balance\ncompeting objectives across target types, the relative importance of different statistics, stability\nof resulting weights, and preservation of household relationships.","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"WelS6sQQkC"}],"key":"QCCZBNMm2E"},{"type":"paragraph","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Users should consult validation metrics for targets most relevant to their analysis.","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"aoJShhhpSp"}],"key":"IAOay3M8Bz"},{"type":"heading","depth":2,"position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"Applications","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"fsyqiX6mJm"}],"identifier":"applications","label":"Applications","html_id":"applications","implicit":true,"key":"yvFChEHQUa"},{"type":"heading","depth":3,"position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[{"type":"text","value":"Tax Policy Analysis","position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"key":"IgjE3usuza"}],"identifier":"tax-policy-analysis","label":"Tax Policy Analysis","html_id":"tax-policy-analysis","implicit":true,"key":"B8bMUdGdCg"},{"type":"paragraph","position":{"start":{"line":72,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"The dataset excels at analyzing federal tax reforms through accurate income distribution at high\nincomes, detailed deduction and credit information, state identifiers for SALT analysis, and\nhousehold structure for family-based policies.","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"dONbqnppHi"}],"key":"VYqMsuHP1s"},{"type":"heading","depth":3,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"State and Local Analysis","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"auNfeCkc6e"}],"identifier":"state-and-local-analysis","label":"State and Local Analysis","html_id":"state-and-local-analysis","implicit":true,"key":"X2hVSm9OHR"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Unlike the PUF, the Enhanced CPS enables state-level studies including state income tax modeling,\ngeographic variation in federal policies, state-specific program interactions, and regional economic\nimpacts.","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"Pb3giMXQ9B"}],"key":"iGmumY0dHz"},{"type":"heading","depth":3,"position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"Integrated Policy Analysis","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"JBUdOiddnP"}],"identifier":"integrated-policy-analysis","label":"Integrated Policy Analysis","html_id":"integrated-policy-analysis","implicit":true,"key":"mBLlCdc94T"},{"type":"paragraph","position":{"start":{"line":84,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"The combination of tax and transfer data supports analysis of universal basic income proposals,\nearned income tax credit expansions, childcare and family benefit reforms, and healthcare subsidy\ndesign.","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"jdrTNuaySr"}],"key":"svc2rI5tks"},{"type":"heading","depth":3,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Microsimulation Model Development","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"jW4rYBFuON"}],"identifier":"microsimulation-model-development","label":"Microsimulation Model Development","html_id":"microsimulation-model-development","implicit":true,"key":"xlzjGiZv7q"},{"type":"paragraph","position":{"start":{"line":90,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"As the foundation for PolicyEngine US, the dataset demonstrates how enhanced microdata improve model\ncapabilities through more accurate baseline distributions, better behavioral response modeling,\nimproved validation against benchmarks, and enhanced credibility of results.","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"HPuI6m0DcD"}],"key":"bfLwqkEH1Y"},{"type":"heading","depth":2,"position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"children":[{"type":"text","value":"Comparison with Alternatives","position":{"start":{"line":94,"column":1},"end":{"line":94,"column":1}},"key":"r9Ja0j9q0e"}],"identifier":"comparison-with-alternatives","label":"Comparison with Alternatives","html_id":"comparison-with-alternatives","implicit":true,"key":"xassn1VTm1"},{"type":"heading","depth":3,"position":{"start":{"line":96,"column":1},"end":{"line":96,"column":1}},"children":[{"type":"text","value":"Versus Synthetic Data","position":{"start":{"line":96,"column":1},"end":{"line":96,"column":1}},"key":"fjHVO5KFce"}],"identifier":"versus-synthetic-data","label":"Versus Synthetic Data","html_id":"versus-synthetic-data","implicit":true,"key":"iczC2AVtC6"},{"type":"paragraph","position":{"start":{"line":98,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"text","value":"Unlike fully synthetic datasets, our approach preserves actual survey responses where possible,\nimputes only missing tax variables, maintains household relationships, and provides transparent\nmethodology.","position":{"start":{"line":98,"column":1},"end":{"line":98,"column":1}},"key":"G93tE56syB"}],"key":"YAT4rK7nTp"},{"type":"heading","depth":3,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"Versus Administrative Data","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"Qnxp5vV6Uy"}],"identifier":"versus-administrative-data","label":"Versus Administrative Data","html_id":"versus-administrative-data","implicit":true,"key":"NIGxrtMsF9"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"While not replacing restricted administrative data, the Enhanced CPS offers public availability,\nhousehold structure, geographic detail, integration with survey content, and no access restrictions.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"GMdj4AoyEm"}],"key":"lmuzV3tGUs"},{"type":"heading","depth":3,"position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"children":[{"type":"text","value":"Versus Other Matching Approaches","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"ujREGp0tcl"}],"identifier":"versus-other-matching-approaches","label":"Versus Other Matching Approaches","html_id":"versus-other-matching-approaches","implicit":true,"key":"cJFfkiWurk"},{"type":"paragraph","position":{"start":{"line":109,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"Compared to traditional statistical matching, QRF better preserves distributions, large-scale\ncalibration ensures consistency, open-source implementation enables replication, and modular design\nallows improvements.","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"s6oPpaIWUu"}],"key":"TP0ePivUVf"},{"type":"heading","depth":2,"position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"children":[{"type":"text","value":"Future Directions","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"BNsAfm07t2"}],"identifier":"future-directions","label":"Future Directions","html_id":"future-directions","implicit":true,"key":"s2hsWRCHR5"},{"type":"heading","depth":3,"position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"Methodological Enhancements","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"AbIo66mvM4"}],"identifier":"methodological-enhancements","label":"Methodological Enhancements","html_id":"methodological-enhancements","implicit":true,"key":"tUme2iqmG2"},{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"Potential improvements include incorporating additional predictors for imputation, using more recent\nadministrative data when available, developing time-series consistency methods, and adding\nuncertainty quantification.","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"FHX8pFGaMM"}],"key":"T3ShLHQiSR"},{"type":"heading","depth":3,"position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"text","value":"Additional Data Integration","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"key":"Zsya5TjHmn"}],"identifier":"additional-data-integration","label":"Additional Data Integration","html_id":"additional-data-integration","implicit":true,"key":"PXYgAqKREj"},{"type":"paragraph","position":{"start":{"line":123,"column":1},"end":{"line":124,"column":1}},"children":[{"type":"text","value":"We could incorporate in future versions state tax return data, program administrative records,\nconsumer expenditure information, and health insurance claims data.","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"key":"FNtItGi3iX"}],"key":"qwrYHLZ0Xl"},{"type":"heading","depth":3,"position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"children":[{"type":"text","value":"Model Development","position":{"start":{"line":126,"column":1},"end":{"line":126,"column":1}},"key":"gvqolpSDRt"}],"identifier":"model-development","label":"Model Development","html_id":"model-development","implicit":true,"key":"RrJSeeA7iM"},{"type":"paragraph","position":{"start":{"line":128,"column":1},"end":{"line":129,"column":1}},"children":[{"type":"text","value":"We could extend the framework to dynamic microsimulation over time, behavioral response estimation,\ngeographic mobility modeling, and life-cycle analysis.","position":{"start":{"line":128,"column":1},"end":{"line":128,"column":1}},"key":"wn9q7eDJpJ"}],"key":"w9E5t2M6Ft"},{"type":"heading","depth":3,"position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"International Applications","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"ZcuS2hzHPX"}],"identifier":"international-applications","label":"International Applications","html_id":"international-applications","implicit":true,"key":"wg9J7cbahS"},{"type":"paragraph","position":{"start":{"line":133,"column":1},"end":{"line":135,"column":1}},"children":[{"type":"text","value":"Researchers could adapt the methodology for other countries facing similar data availability\nchallenges, need for tax-benefit integration, open-source implementation requirements, and\ncross-national comparison needs.","position":{"start":{"line":133,"column":1},"end":{"line":133,"column":1}},"key":"X5fSp5i6AD"}],"key":"GAxOOxd17o"},{"type":"heading","depth":2,"position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"children":[{"type":"text","value":"Conclusion for Researchers","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"rbFd0Fn78d"}],"identifier":"conclusion-for-researchers","label":"Conclusion for Researchers","html_id":"conclusion-for-researchers","implicit":true,"key":"uLV3iA4BVi"},{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":142,"column":1}},"children":[{"type":"text","value":"The Enhanced CPS provides a valuable resource for policy analysis, though users should understand\nthe limitations (particularly temporal inconsistency), validate results against external benchmarks,\nconsider sensitivity to methodological choices, and contribute improvements to the open-source\nproject.","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"WgpkFHWC2X"}],"key":"E0V5Ij5GWr"},{"type":"paragraph","position":{"start":{"line":144,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"text","value":"The dataset represents a pragmatic solution to data limitations. It enables analyses that advance\nour understanding of tax and transfer policy impacts while we await improved data access.","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"gdfN7PUTM6"}],"key":"YioMhv3Huw"}],"key":"O59YbgvNnc"}],"key":"b1RVZyyWHx"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Calibration Pipeline User’s Manual","url":"/calibration","group":"PolicyEngine US Data"},"next":{"title":"Conclusion","url":"/conclusion","group":"PolicyEngine US Data"}}},"domain":"http://localhost:3000"}